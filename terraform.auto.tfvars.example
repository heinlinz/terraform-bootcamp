# ============================================================================
# IMPORTANT: GitHub Actions Secrets Configuration
# ============================================================================
# The following sensitive values MUST be configured as secrets in your 
# GitHub repository before running CI/CD pipelines:
#
# 1. AWS_ACCESS_KEY_ID - AWS IAM user access key
# 2. AWS_SECRET_ACCESS_KEY - AWS IAM user secret key
# 3. AWS_REGION - AWS region (e.g., ap-southeast-1)
# 4. TF_VAR_certificate_arn - ACM certificate ARN for HTTPS
# 5. TF_VAR_db_password - RDS database password
#
# To add secrets in GitHub:
# 1. Go to Settings > Secrets and variables > Actions
# 2. Click "New repository secret"
# 3. Add each secret with the exact name listed above
# 4. Use the secret in GitHub Actions workflows with: ${{ secrets.SECRET_NAME }}
#
# Example GitHub Actions workflow snippet:
# env:
#   AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}
#   AWS_SECRET_ACCESS_KEY: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
#   AWS_REGION: ${{ secrets.AWS_REGION }}
#   TF_VAR_certificate_arn: ${{ secrets.TF_VAR_certificate_arn }}
#   TF_VAR_db_password: ${{ secrets.TF_VAR_db_password }}
# ============================================================================

############################################################
## Network Configuration
############################################################
cidr_block       = "10.0.0.0/16"
public_subnet_1  = "10.0.1.0/24"
public_subnet_2  = "10.0.2.0/24"
private_subnet_1 = "10.0.3.0/24"
private_subnet_2 = "10.0.4.0/24"

############################################################
## Project Configuration
############################################################
project_name  = "velocity"
environment   = "production"
instance_type = "t3.medium"

############################################################
## Load Balancer Configuration
############################################################
alb_name = "velocity-alb"

# NOTE: Replace with your actual domain and certificate ARN from AWS ACM
# Get certificate_arn from: AWS Console > Certificate Manager > Certificates
domain_name     = "example.com"
certificate_arn = "arn:aws:acm:ap-southeast-1:ACCOUNT_ID:certificate/CERTIFICATE_ID"

############################################################
## IAM Configuration
############################################################
policy_name           = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
instance_profile_name = "velocity-ec2-ssm"
ec2_role_name         = "velocity_ec2_role"

############################################################
## RDS Database Configuration
############################################################
# NOTE: db_password MUST be set as a GitHub Actions secret (TF_VAR_db_password)
# Do NOT commit actual password to version control
db_name           = "velocitydb"
db_engine         = "mysql"
db_engine_version = "8.4"
db_instance_class = "db.t3.micro"
db_user           = "admin"
db_password       = "REPLACE_WITH_STRONG_PASSWORD_IN_GITHUB_SECRETS"